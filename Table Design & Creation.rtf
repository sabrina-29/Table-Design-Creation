CREATE DATABASE CardioHealthDB;\
GO\
\
USE CardioHealthDB;\
GO\
\
\
CREATE TABLE Patients (\
    PatientID INT IDENTITY(1,1) PRIMARY KEY,\
    Gender TINYINT NOT NULL CHECK (Gender IN (1,2)),   -- 1=Male, 2=Female\
    BirthDate DATE NOT NULL,\
    Height SMALLINT NOT NULL CHECK (Height BETWEEN 120 AND 250),\
    Weight DECIMAL(5,2) NOT NULL CHECK (Weight BETWEEN 30 AND 250)\
);\
GO\
\
CREATE TABLE Measurements (\
    MeasureID INT IDENTITY(1,1) PRIMARY KEY,\
    PatientID INT NOT NULL,\
    SystolicBP SMALLINT NOT NULL CHECK (SystolicBP BETWEEN 80 AND 250),\
    DiastolicBP SMALLINT NOT NULL CHECK (DiastolicBP BETWEEN 40 AND 150),\
    BMI DECIMAL(4,1) CHECK (BMI BETWEEN 10 AND 60),\
    MeasureDate DATE NOT NULL,\
\
    CONSTRAINT FK_Measurements_Patient\
        FOREIGN KEY (PatientID) REFERENCES Patients(PatientID),\
\
    CONSTRAINT CHK_BP_Logic\
        CHECK (SystolicBP > DiastolicBP)\
);\
GO\
\
CREATE TABLE Medical_Status (\
    StatusID INT IDENTITY(1,1) PRIMARY KEY,\
    PatientID INT NOT NULL,\
    Cholesterol TINYINT NOT NULL CHECK (Cholesterol IN (1,2,3)),\
    Glucose TINYINT NOT NULL CHECK (Glucose IN (1,2,3)),\
\
    CONSTRAINT FK_Status_Patient\
        FOREIGN KEY (PatientID) REFERENCES Patients(PatientID)\
);\
GO\
\
CREATE TABLE Lifestyle (\
    LifestyleID INT IDENTITY(1,1) PRIMARY KEY,\
    PatientID INT NOT NULL UNIQUE,\
    Smoking BIT NOT NULL,\
    Alcohol BIT NOT NULL,\
    PhysicalActivity BIT NOT NULL,\
\
    CONSTRAINT FK_Lifestyle_Patient\
        FOREIGN KEY (PatientID) REFERENCES Patients(PatientID)\
);\
GO\
\
CREATE TABLE Diagnosis (\
    DiagnosisID INT IDENTITY(1,1) PRIMARY KEY,\
    PatientID INT NOT NULL UNIQUE,\
    CardioDisease BIT NOT NULL,\
\
    CONSTRAINT FK_Diagnosis_Patient\
        FOREIGN KEY (PatientID) REFERENCES Patients(PatientID)\
);\
GO\
